# Copy this file to .env for local development. The :local npm scripts load .env automatically.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/solar_tracker
# Change PORT if 5000 is already in use on your machine.
PORT=5000

# Optional in local development, but required for hosted deployments.
# When unset in development, the app skips the login screen.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
SESSION_SECRET=replace-this-with-a-long-random-string

# Scheduler and seed defaults
SEED_ON_BOOT=false
ENABLE_INTERNAL_SCHEDULER=true
SYNC_CRON=0 1 * * *
SYNC_TIMEZONE=America/Chicago

# Required only if you use an external scheduler such as GitHub Actions
CRON_SECRET=replace-this-with-a-random-secret

# Optional credential-based scraper examples
# SOLAR_PORTAL_1_USERNAME=you@example.com
# SOLAR_PORTAL_1_PASSWORD=super-secret
# SOLAR_PORTAL_1_URL=https://portal.example.com
# SOLAR_PORTAL_1_API_KEY=example-api-key
